NODE_ENV=development
PORT=4000

# Required Firebase Admin credential for the backend.
# Keep the JSON on one line with escaped newlines in private_key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com"}

# Browser origins allowed to call the backend.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Current-stack defaults
PAYWALL_AMOUNT_USD=13
AUTH_COOKIE_MAX_AGE_SECONDS=1800
RATE_LIMIT_MAX_BUCKETS=10000

# Optional Paddle billing configuration
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
